ENV=dev
LOG_LEVEL=INFO

# Aliyun PNVS — 短信认证 (new product). Personal real-name auth is enough.
# Create a RAM sub-user with AliyunDypnsapiFullAccess policy:
#   https://ram.console.aliyun.com/users
# Leave empty during local dev → backend uses MockSmsSender (accepts code "000000").
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_PNVS_ENDPOINT=dypnsapi.aliyuncs.com

# System-provided signature + template for the new "短信认证" product.
# Defaults match what Aliyun preconfigures for individual developers — usually no need to change.
# ALIYUN_PNVS_SIGN_NAME=速通互联验证码
# ALIYUN_PNVS_TEMPLATE_CODE=100001
# ALIYUN_PNVS_CODE_VALID_SECONDS=300

# Aliyun Captcha 2.0 — anti-bot challenge before /sms/send.
# Get scene_id from https://yundun.console.aliyun.com/?p=captchanext after creating a scene.
# Empty = skip captcha (DEV ONLY — exposes you to SMS bombing).
ALIYUN_CAPTCHA_SCENE_ID=
ALIYUN_CAPTCHA_ENDPOINT=captcha.cn-shanghai.aliyuncs.com

# Supabase (Postgres for user storage). Leave empty for in-memory dev mode.
# Get these from Supabase dashboard → Project Settings → API.
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   ⚠️ NEVER commit; bypasses RLS.

# JWT — we sign our own tokens. Generate a 32+ byte random secret for prod:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-do-not-use-in-prod-please-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000
